# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Polymarket
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLYMARKET_CHAIN_ID=137
BTC_WS_URL=wss://stream.binance.com:9443/stream
BTC_SYMBOL=btcusdt
BTC_REST_FALLBACK_URL=https://api.binance.com/api/v3/ticker/price
WS_RECONNECT_BACKOFF_SECONDS=2.0
WS_RECONNECT_BACKOFF_MAX_SECONDS=30.0
DAEMON_DISCOVERY_INTERVAL_SECONDS=60
DAEMON_DECISION_MIN_INTERVAL_SECONDS=1.0
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=0
LIVE_TRADING_ENABLED=false
LIVE_ORDER_TYPE=FOK
LIVE_POST_ONLY=false

# Runtime
TRADING_MODE=paper
MARKET_FAMILY=btc_1h
LOOP_SECONDS=15
MAX_POSITION_USD=10
MIN_CONFIDENCE=0.75
MIN_EDGE=0.03
MAX_SPREAD=0.04
MIN_DEPTH_USD=200
EXIT_BUFFER_SECONDS=5
MAX_DAILY_LOSS_USD=25
